# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/mindbridge"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get a free API key at https://resend.com — 3,000 emails/month free tier
# Leave blank to skip sending (emails logged to console instead)
RESEND_API_KEY=re_xxxxxxxxxxxx


# ── Frontend URL (used in email links) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Google OAuth 2.0 (Continue with Google) ──────────────────────────────────
# OAuth Web Client ID from Google Cloud Console → APIs & Services → Credentials.
# ID-token flow: only the Client ID is needed — no secret, no callback URL.
# The same value goes in Frontend/.env as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=