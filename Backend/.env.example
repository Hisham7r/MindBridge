# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/mindbridge"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
